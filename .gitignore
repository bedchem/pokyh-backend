# ─── Secrets / environment — NEVER commit ────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
# (.env.example IS committed — it documents the variables, no secrets)

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
admin/node_modules/
.pnp
.pnp.js

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
admin/dist/
build/
*.tsbuildinfo

# ─── Prisma ───────────────────────────────────────────────────────────────────
prisma/migrations/
*.db
*.db-journal
*.sqlite
*.sqlite3

# ─── Database dumps / backups (incl. JSON export/import files) ────────────────
*.sql
*.sql.gz
*.dump
pokyh-export-*.json

# ─── Cloudflare tunnel credentials (contain secrets) ──────────────────────────
~/.cloudflared/*.json
*.cloudflared.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test / coverage artifacts ────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editors / IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Misc / tooling ───────────────────────────────────────────────────────────
tmp/
.tmp/
.cache/
.claude/
