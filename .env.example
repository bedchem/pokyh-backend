# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Use the docker-compose service name "mysql" (NOT localhost) when in Docker.
# Format: mysql://root:<password>@<host>:3306/<database>
DATABASE_URL=mysql://root:CHANGE_ME_DB_PASSWORD@mysql:3306/pokyh
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── App secrets ───────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
# Each must be unique, at least 32 characters. Never reuse across deployments.
JWT_SECRET=
REFRESH_TOKEN_SECRET=
API_KEY=
SERVER_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
CORS_ORIGIN=https://app.yourdomain.com

# ── Admin panel login ─────────────────────────────────────────────────────────
# Leave blank on first start — setup wizard at /admin/ will configure these.
# ADMIN_USERNAMES: comma-separated for multiple admins.
# ADMIN_PASSWORD_HASH: bcrypt hash (cost 12+).
#   Generate:  node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
# IMPORTANT: Do NOT wrap in quotes — docker-compose env_file reads values literally.
ADMIN_USERNAME=
ADMIN_USERNAMES=
ADMIN_PASSWORD_HASH=

# ── Cloudflare tunnel ─────────────────────────────────────────────────────────
# Set automatically by the admin setup wizard, or manually here.
# TUNNEL_NAME     — cloudflared tunnel name    (e.g. my-api-tunnel)
# TUNNEL_HOSTNAME — public hostname            (e.g. api.yourdomain.com)
# Also used by scripts/setup-tunnel.sh — both values must be set to use that script.
TUNNEL_NAME=
TUNNEL_HOSTNAME=

# ── WebUntis integration ──────────────────────────────────────────────────────
# Your WebUntis instance base URL and school identifier.
WEBUNTIS_BASE=https://yourschool.webuntis.com/WebUntis
WEBUNTIS_SCHOOL=yourschool

# ── Debug (development only) ──────────────────────────────────────────────────
DEBUG=false
