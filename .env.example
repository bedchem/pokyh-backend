# ── Database ───────────────────────────────────────────────────────────────────
# IMPORTANT: DATABASE_URL must be set explicitly — docker-compose no longer constructs it.
# Use the service name "mysql" (not localhost) when running in Docker.
DATABASE_URL=mysql://root:<MYSQL_ROOT_PASSWORD>@mysql:3306/pokyh
MYSQL_ROOT_PASSWORD=changeme_use_a_strong_password

# ── App secrets (generate with: openssl rand -hex 32) ─────────────────────────
JWT_SECRET=
REFRESH_TOKEN_SECRET=
API_KEY=
SERVER_KEY=

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
CORS_ORIGIN=https://yourdomain.com,https://api.yourdomain.com

# ── Admin panel login ─────────────────────────────────────────────────────────
# Leave blank on first start — the setup wizard at /admin/ will set these
ADMIN_USERNAME=
ADMIN_USERNAMES=
ADMIN_PASSWORD_HASH=

# ── Cloudflare tunnel (set by the admin setup wizard) ─────────────────────────
TUNNEL_NAME=
TUNNEL_HOSTNAME=

# ── WebUntis ──────────────────────────────────────────────────────────────────
WEBUNTIS_BASE=https://lbs-brixen.webuntis.com/WebUntis
WEBUNTIS_SCHOOL=lbs-brixen

# ── Debug (set true only in development) ──────────────────────────────────────
DEBUG=false
