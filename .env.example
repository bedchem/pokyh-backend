NODE_ENV=production
PORT=4000

# Express trust-proxy setting. Behind the Cloudflare tunnel the client IP comes
# via X-Forwarded-For; this declares how many/which proxies to trust so rate
# limiting works (default 'loopback'). Use 'true', 'false', a hop count, or a
# named value. Set to a number (e.g. 2) if you add Traefik/another proxy hop.
TRUST_PROXY=loopback

# MySQL (matches docker-compose service name — do NOT change to localhost)
DATABASE_URL=mysql://root:CHANGE_ME@mysql:3306/pokyh
MYSQL_ROOT_PASSWORD=CHANGE_ME

# Discrete DB connection fields. If DATABASE_URL is left blank it is built from
# these (user/password URL-encoded automatically). DATABASE_URL wins when set.
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=pokyh
DB_CONNECTION_LIMIT=20
DB_AUTO_PUSH=true
DB_PUSH_TIMEOUT_MS=120000
DB_CONNECT_BASE_DELAY_MS=2000
DB_CONNECT_MAX_DELAY_MS=30000

# JWT / API secrets — generate each with: openssl rand -hex 32
JWT_SECRET=
REFRESH_TOKEN_SECRET=
API_KEY=
SERVER_KEY=

# CORS — comma-separated origins, no trailing slash
CORS_ORIGIN=https://yourdomain.com

# Admin accounts
# Leave blank on first start — setup wizard at /admin/ will configure these.
# Generate hash: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
# Do NOT wrap value in quotes — docker-compose env_file reads it literally.
ADMIN_USERNAME=
ADMIN_USERNAMES=
ADMIN_PASSWORD_HASH=

# WebUntis
WEBUNTIS_BASE=https://yourschool.webuntis.com/WebUntis
WEBUNTIS_SCHOOL=yourschool

# Cloudflare Tunnel — also used by scripts/setup-tunnel.sh
TUNNEL_NAME=
TUNNEL_HOSTNAME=

DEBUG=false

# ─── Auth / tokens (all optional — shown with their defaults) ────────────────
JWT_EXPIRES_IN=1h
ADMIN_JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_HOURS=1
BCRYPT_ROUNDS=12

# ─── Rate limiting (requests per window; windows in ms) ──────────────────────
RATE_LIMIT_GLOBAL_MAX=500
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_READ_MAX=300
RATE_LIMIT_READ_WINDOW_MS=60000
RATE_LIMIT_SSE_MAX=10
RATE_LIMIT_SSE_WINDOW_MS=60000
RATE_LIMIT_ADMIN_LOGIN_MAX=10
RATE_LIMIT_ADMIN_LOGIN_WINDOW_MS=900000

# ─── Request body size limits ────────────────────────────────────────────────
BODY_LIMIT=10kb
BODY_LIMIT_UPLOAD=4mb
BODY_LIMIT_IMPORT=100mb

# ─── Background job intervals (ms) ───────────────────────────────────────────
PUSH_POLL_INTERVAL_MS=300000
PUSH_DUE_CHECK_INTERVAL_MS=60000
SESSION_CLEANUP_INTERVAL_MS=3600000

# ─── Archiving of expired todos/reminders ────────────────────────────────────
ARCHIVE_AFTER_HOURS=24
ARCHIVE_CHECK_INTERVAL_MS=3600000

# ─── School year rollover ─────────────────────────────────────────────────────
# On the configured date (default Aug 1) all non-admin users, classes, todos and
# reminders are snapshotted into the school_years archive tables and the live
# tables are cleared so the new year starts fresh. Set AUTO=false to disable.
SCHOOL_YEAR_ROLLOVER_AUTO=true
SCHOOL_YEAR_ROLLOVER_CHECK_INTERVAL_MS=3600000
# Month (1-12) and day for the rollover. Defaults to August 1st.
SCHOOL_YEAR_ROLLOVER_MONTH=8
SCHOOL_YEAR_ROLLOVER_DAY=1

# ─── In-memory cache TTL (ms) ────────────────────────────────────────────────
CACHE_TTL_MS=300000

# ─── Misc ────────────────────────────────────────────────────────────────────
SSE_HEARTBEAT_MS=30000
MENSA_IMPORT_URL=https://mensa.plattnericus.dev/mensa.json
PUBLIC_BASE_URL=
