# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Use the docker-compose service name "mysql" (NOT localhost) when running in Docker.
# Format: mysql://root:<password>@<host>:3306/<database>
DATABASE_URL=mysql://root:CHANGE_ME_DB_PASSWORD@mysql:3306/pokyh
MYSQL_ROOT_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── App secrets ───────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
# Each must be unique and at least 32 characters. Never reuse across deployments.
JWT_SECRET=
REFRESH_TOKEN_SECRET=
API_KEY=
SERVER_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://app.yourdomain.com,https://api.yourdomain.com
CORS_ORIGIN=https://app.yourdomain.com

# ── Admin panel login ─────────────────────────────────────────────────────────
# Leave blank on first start — the setup wizard at /admin/ will configure these.
# ADMIN_USERNAMES is a comma-separated list for multiple admins.
# ADMIN_PASSWORD_HASH must be a bcrypt hash (cost 12+).
#   Generate:  node -e "const b=require('bcrypt'); b.hash('yourpassword',12).then(console.log)"
# IMPORTANT: Wrap value in single quotes in .env to prevent $-sign interpolation.
ADMIN_USERNAME=
ADMIN_USERNAMES=
ADMIN_PASSWORD_HASH=''

# ── Cloudflare tunnel ─────────────────────────────────────────────────────────
# Set automatically by the admin setup wizard.
# TUNNEL_NAME  — the cloudflared tunnel name (e.g. my-api-tunnel)
# TUNNEL_HOSTNAME — the public hostname (e.g. api.yourdomain.com)
TUNNEL_NAME=
TUNNEL_HOSTNAME=

# ── WebUntis integration ──────────────────────────────────────────────────────
# Your WebUntis instance base URL and school identifier.
# Example: https://yourschool.webuntis.com/WebUntis
WEBUNTIS_BASE=
WEBUNTIS_SCHOOL=

# ── Debug (development only) ──────────────────────────────────────────────────
DEBUG=false
