{
  "name": "pokyh-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:setup": "prisma db push",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "make-admin": "node scripts/make-admin.js",
    "revoke-admin": "node scripts/revoke-admin.js",
    "set-admin-password": "node scripts/set-admin-password.js",
    "create-user": "node scripts/create-user.js",
    "admin:build": "cd admin && npm install && npm run build",
    "admin:dev": "cd admin && npm run dev",
    "tunnel": "cloudflared tunnel run pokyh-api"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/morgan": "^1.9.10",
    "@types/sharp": "^0.31.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "uuid": "^11.0.3",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
