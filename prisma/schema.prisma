// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  stableUid           String    @unique @map("stable_uid")
  username            String    @unique
  webuntisKlasseId    Int       @map("webuntis_klasse_id")
  webuntisKlasseName  String    @map("webuntis_klasse_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  todos         Todo[]
  classMembers  ClassMember[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Admin {
  stableUid       String   @id @map("stable_uid")
  canCreateClass  Boolean  @default(true) @map("can_create_class")
  passwordHash    String?  @map("password_hash") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Class {
  id               String   @id
  name             String
  code             String   @unique @db.Char(6)
  webuntisKlasseId Int      @map("webuntis_klasse_id")
  createdBy        String   @map("created_by")
  createdByName    String   @map("created_by_name")
  createdAt        DateTime @default(now()) @map("created_at")

  members   ClassMember[]
  reminders Reminder[]

  @@map("classes")
}

model ClassMember {
  classId   String   @map("class_id")
  stableUid String   @map("stable_uid")
  username  String
  joinedAt  DateTime @default(now()) @map("joined_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@id([classId, stableUid])
  @@map("class_members")
}

model Todo {
  id        String    @id @default(uuid())
  stableUid String    @map("stable_uid")
  title     String    @db.VarChar(500)
  details   String    @default("") @db.VarChar(5000)
  dueAt     DateTime? @map("due_at")
  done      Boolean   @default(false)
  doneAt    DateTime? @map("done_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("todos")
}

model Reminder {
  id                String   @id @default(uuid())
  classId           String   @map("class_id")
  title             String   @db.VarChar(500)
  body              String   @default("") @db.VarChar(5000)
  remindAt          DateTime @map("remind_at")
  createdBy         String   @map("created_by")
  createdByName     String   @map("created_by_name")
  createdByUsername String   @map("created_by_username")
  createdAt         DateTime @default(now()) @map("created_at")

  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@map("reminders")
}

model Comment {
  id         String   @id @default(uuid())
  reminderId String   @map("reminder_id")
  classId    String   @map("class_id")
  stableUid  String   @map("stable_uid")
  username   String
  body       String   @db.VarChar(2000)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@map("comments")
}

model DishComment {
  id        String   @id @default(uuid())
  dishId    String   @map("dish_id")
  stableUid String   @map("stable_uid")
  username  String
  body      String   @db.VarChar(2000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dishId])
  @@map("dish_comments")
}

model Dish {
  id           String   @id @default(uuid())
  nameDe       String   @map("name_de") @db.VarChar(500)
  nameIt       String   @default("") @map("name_it") @db.VarChar(500)
  nameEn       String   @default("") @map("name_en") @db.VarChar(500)
  descDe       String   @default("") @map("desc_de") @db.VarChar(2000)
  descIt       String   @default("") @map("desc_it") @db.VarChar(2000)
  descEn       String   @default("") @map("desc_en") @db.VarChar(2000)
  imageUrl     String   @default("") @map("image_url") @db.VarChar(1000)
  category     String   @default("") @db.VarChar(200)
  tags         String   @default("[]") @db.VarChar(2000)
  prepTime     Int      @default(0) @map("prep_time")
  calories     Int      @default(0)
  price        Float    @default(0)
  protein      Float    @default(0)
  fat          Float    @default(0)
  allergens    String   @default("[]") @db.VarChar(2000)
  isVegetarian Boolean  @default(false) @map("is_vegetarian")
  isVegan      Boolean  @default(false) @map("is_vegan")
  date         DateTime @db.Date
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("dishes")
}

model DishRating {
  dishId    String   @map("dish_id")
  stableUid String   @map("stable_uid")
  stars     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([dishId, stableUid])
  @@map("dish_ratings")
}

model RefreshToken {
  id        String    @id @default(uuid())
  stableUid String    @map("stable_uid")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("refresh_tokens")
}

model KnownSubject {
  key       String   @id @db.VarChar(200)
  longName  String   @map("long_name") @db.VarChar(200)
  shortName String   @map("short_name") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("known_subjects")
}

model SubjectImage {
  subject   String   @id @db.VarChar(200)
  data      Bytes    @db.LongBlob
  mimeType  String   @map("mime_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subject_images")
}

model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique @map("key_hash")
  name       String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("api_keys")
}

model RequestLog {
  id        String   @id @default(uuid())
  method    String   @db.VarChar(10)
  path      String   @db.VarChar(500)
  status    Int
  duration  Int
  ip        String?  @db.VarChar(45)
  stableUid String?  @map("stable_uid") @db.VarChar(64)
  username  String?  @db.VarChar(100)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  error     String?  @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stableUid])
  @@index([username])
  @@index([createdAt])
  @@map("request_logs")
}

model FrontendActivityLog {
  id        String   @id @default(uuid())
  event     String   @db.VarChar(50)
  page      String?  @db.VarChar(500)
  detail    String?  @db.VarChar(500)
  stableUid String?  @map("stable_uid") @db.VarChar(64)
  username  String?  @db.VarChar(100)
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stableUid])
  @@index([username])
  @@index([createdAt])
  @@index([event])
  @@map("frontend_activity_logs")
}
