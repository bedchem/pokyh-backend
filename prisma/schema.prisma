// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  stableUid           String    @unique @map("stable_uid")
  username            String    @unique
  webuntisKlasseId    Int       @map("webuntis_klasse_id")
  webuntisKlasseName  String    @map("webuntis_klasse_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  todos         Todo[]
  classMembers  ClassMember[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Admin {
  stableUid       String   @id @map("stable_uid")
  canCreateClass  Boolean  @default(true) @map("can_create_class")
  passwordHash    String?  @map("password_hash") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Class {
  id               String   @id
  name             String
  code             String   @unique @db.Char(6)
  webuntisKlasseId Int      @map("webuntis_klasse_id")
  createdBy        String   @map("created_by")
  createdByName    String   @map("created_by_name")
  createdAt        DateTime @default(now()) @map("created_at")

  members   ClassMember[]
  reminders Reminder[]

  @@map("classes")
}

model ClassMember {
  classId   String   @map("class_id")
  stableUid String   @map("stable_uid")
  username  String
  joinedAt  DateTime @default(now()) @map("joined_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@id([classId, stableUid])
  @@map("class_members")
}

model Todo {
  id        String    @id @default(uuid())
  stableUid String    @map("stable_uid")
  title     String    @db.VarChar(500)
  details   String    @default("") @db.VarChar(5000)
  dueAt     DateTime? @map("due_at")
  done      Boolean   @default(false)
  doneAt    DateTime? @map("done_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("todos")
}

model Reminder {
  id                String   @id @default(uuid())
  classId           String   @map("class_id")
  title             String   @db.VarChar(500)
  body              String   @default("") @db.VarChar(5000)
  remindAt          DateTime @map("remind_at")
  createdBy         String   @map("created_by")
  createdByName     String   @map("created_by_name")
  createdByUsername String   @map("created_by_username")
  createdAt         DateTime @default(now()) @map("created_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model DishRating {
  dishId    String   @map("dish_id")
  stableUid String   @map("stable_uid")
  stars     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([dishId, stableUid])
  @@map("dish_ratings")
}

model RefreshToken {
  id        String    @id @default(uuid())
  stableUid String    @map("stable_uid")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique @map("key_hash")
  name       String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("api_keys")
}

model RequestLog {
  id        String   @id @default(uuid())
  method    String   @db.VarChar(10)
  path      String   @db.VarChar(500)
  status    Int
  duration  Int
  ip        String?  @db.VarChar(45)
  stableUid String?  @map("stable_uid") @db.VarChar(64)
  username  String?  @db.VarChar(100)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  error     String?  @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stableUid])
  @@index([username])
  @@index([createdAt])
  @@map("request_logs")
}
