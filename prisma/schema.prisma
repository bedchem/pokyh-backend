// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  stableUid           String    @unique @map("stable_uid")
  username            String    @unique
  webuntisKlasseId    Int       @default(0) @map("webuntis_klasse_id")
  webuntisKlasseName  String    @default("") @map("webuntis_klasse_name")
  passwordHash        String?   @map("password_hash") @db.VarChar(100)
  isUntisUser         Boolean   @default(true) @map("is_untis_user")
  // Account role: "student" (default) or "parent". Parents have their own todos,
  // see only the class name (never appear in member lists) and have no reminders.
  role                String    @default("student") @db.VarChar(20)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  todos              Todo[]
  classMembers       ClassMember[]
  refreshTokens      RefreshToken[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

model PushSubscription {
  id           String   @id @default(uuid())
  stableUid    String   @map("stable_uid")
  endpoint     String   @unique @db.VarChar(500)
  p256dh       String   @db.VarChar(255)
  auth         String   @db.VarChar(255)
  jsessionid   String   @db.VarChar(100)
  bearerToken  String   @map("bearer_token") @db.VarChar(1000)
  knownUnread  Int      @default(-1) @map("known_unread")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Admin {
  stableUid       String   @id @map("stable_uid")
  canCreateClass  Boolean  @default(true) @map("can_create_class")
  passwordHash    String?  @map("password_hash") @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Class {
  id               String   @id
  name             String
  code             String   @unique @db.Char(6)
  webuntisKlasseId Int      @map("webuntis_klasse_id")
  createdBy        String   @map("created_by")
  createdByName    String   @map("created_by_name")
  createdAt        DateTime @default(now()) @map("created_at")

  members   ClassMember[]
  reminders Reminder[]

  @@map("classes")
}

model ClassMember {
  classId   String   @map("class_id")
  stableUid String   @map("stable_uid")
  username  String
  // "student" members are visible in the class; "parent" members are hidden
  // (they can see the class name but never appear in the member list).
  role      String   @default("student") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@id([classId, stableUid])
  @@index([stableUid])
  @@map("class_members")
}

model Todo {
  id          String    @id @default(uuid())
  stableUid   String    @map("stable_uid")
  title       String    @db.VarChar(500)
  details     String    @default("") @db.VarChar(5000)
  dueAt       DateTime? @map("due_at")
  done        Boolean   @default(false)
  doneAt      DateTime? @map("done_at")
  notifiedAt  DateTime? @map("notified_at")
  // Set once a todo has been expired (overdue) for >24h. Archived todos are
  // hidden from users and live on the server only — viewable by admins.
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@index([stableUid, archivedAt])
  @@index([archivedAt])
  // Speeds the per-minute "due todos" notification scan.
  @@index([notifiedAt, dueAt])
  @@map("todos")
}

model Reminder {
  id                String    @id @default(uuid())
  classId           String    @map("class_id")
  title             String    @db.VarChar(500)
  body              String    @default("") @db.VarChar(5000)
  remindAt          DateTime  @map("remind_at")
  createdBy         String    @map("created_by")
  createdByName     String    @map("created_by_name")
  createdByUsername String    @map("created_by_username")
  notifiedAt        DateTime? @map("notified_at")
  // Set once a reminder has been expired for >24h. Archived reminders are hidden
  // from class members and live on the server only — viewable by admins.
  archivedAt        DateTime? @map("archived_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([classId, archivedAt])
  @@index([archivedAt])
  // Speeds the per-minute "due reminders" notification scan.
  @@index([notifiedAt, remindAt])
  @@map("reminders")
}

model Comment {
  id         String   @id @default(uuid())
  reminderId String   @map("reminder_id")
  classId    String   @map("class_id")
  stableUid  String   @map("stable_uid")
  username   String
  body       String   @db.VarChar(2000)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@map("comments")
}

model DishComment {
  id        String   @id @default(uuid())
  dishId    String   @map("dish_id")
  stableUid String   @map("stable_uid")
  username  String
  body      String   @db.VarChar(2000)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dishId])
  @@map("dish_comments")
}

model Dish {
  id           String   @id @default(uuid())
  nameDe       String   @map("name_de") @db.VarChar(500)
  nameIt       String   @default("") @map("name_it") @db.VarChar(500)
  nameEn       String   @default("") @map("name_en") @db.VarChar(500)
  descDe       String   @default("") @map("desc_de") @db.VarChar(2000)
  descIt       String   @default("") @map("desc_it") @db.VarChar(2000)
  descEn       String   @default("") @map("desc_en") @db.VarChar(2000)
  imageUrl     String   @default("") @map("image_url") @db.VarChar(1000)
  category     String   @default("") @db.VarChar(200)
  tags         String   @default("[]") @db.VarChar(2000)
  prepTime     Int      @default(0) @map("prep_time")
  calories     Int      @default(0)
  price        Float    @default(0)
  protein      Float    @default(0)
  fat          Float    @default(0)
  allergens    String   @default("[]") @db.VarChar(2000)
  isVegetarian Boolean  @default(false) @map("is_vegetarian")
  isVegan      Boolean  @default(false) @map("is_vegan")
  date         DateTime @db.Date
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("dishes")
}

model DishImage {
  dishId    String   @id @map("dish_id")
  data      Bytes    @db.LongBlob
  mimeType  String   @map("mime_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dish_images")
}

model DishRating {
  dishId    String   @map("dish_id")
  stableUid String   @map("stable_uid")
  stars     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([dishId, stableUid])
  @@map("dish_ratings")
}

model RefreshToken {
  id        String    @id @default(uuid())
  stableUid String    @map("stable_uid")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [stableUid], references: [stableUid], onDelete: Cascade)

  @@map("refresh_tokens")
}

model KnownSubject {
  key       String   @id @db.VarChar(200)
  longName  String   @map("long_name") @db.VarChar(200)
  shortName String   @map("short_name") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("known_subjects")
}

model SubjectImage {
  subject   String   @id @db.VarChar(200)
  data      Bytes    @db.LongBlob
  mimeType  String   @map("mime_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subject_images")
}

model ApiKey {
  id         String    @id @default(uuid())
  keyHash    String    @unique @map("key_hash")
  name       String
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("api_keys")
}

model RequestLog {
  id        String   @id @default(uuid())
  method    String   @db.VarChar(10)
  path      String   @db.VarChar(500)
  status    Int
  duration  Int
  ip        String?  @db.VarChar(45)
  stableUid String?  @map("stable_uid") @db.VarChar(64)
  username  String?  @db.VarChar(100)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  error     String?  @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stableUid])
  @@index([username])
  @@index([createdAt])
  @@map("request_logs")
}

// ─── School year archive ──────────────────────────────────────────────────────
// On August 1st each year the live non-admin users, classes, todos and reminders
// are snapshotted here and then removed from the live tables so the new school
// year starts fresh. Admins (Admin table) keep their User records untouched.

model SchoolYear {
  id        String   @id @default(uuid())
  label     String   @unique           // "2025/2026"
  startYear Int      @unique           @map("start_year")  // 2025
  rolledAt  DateTime @map("rolled_at") // when rollover was performed
  note      String   @default("") @db.VarChar(500)
  createdAt DateTime @default(now())   @map("created_at")

  archivedUsers     ArchivedUser[]
  archivedClasses   ArchivedClass[]
  archivedTodos     ArchivedTodo[]
  archivedReminders ArchivedReminder[]

  @@map("school_years")
}

model ArchivedUser {
  id                 String   @id @default(uuid())
  schoolYearId       String   @map("school_year_id")
  stableUid          String   @map("stable_uid")
  username           String
  role               String   @default("student") @db.VarChar(20)
  webuntisKlasseId   Int      @default(0) @map("webuntis_klasse_id")
  webuntisKlasseName String   @default("") @db.VarChar(255) @map("webuntis_klasse_name")
  classId            String?  @map("class_id")
  classCode          String?  @map("class_code")
  className          String?  @map("class_name")
  createdAt          DateTime @map("created_at")

  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@index([schoolYearId])
  @@index([schoolYearId, stableUid])
  @@map("archived_users")
}

model ArchivedClass {
  id               String   @id @default(uuid())
  schoolYearId     String   @map("school_year_id")
  originalId       String   @map("original_id")
  name             String
  code             String   @db.Char(6)
  webuntisKlasseId Int      @default(0) @map("webuntis_klasse_id")
  createdBy        String   @map("created_by")
  createdByName    String   @default("") @map("created_by_name")
  memberCount      Int      @default(0) @map("member_count")
  membersJson      String   @default("[]") @db.Text @map("members_json")
  createdAt        DateTime @map("created_at")

  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@index([schoolYearId])
  @@map("archived_classes")
}

model ArchivedTodo {
  id           String    @id @default(uuid())
  schoolYearId String    @map("school_year_id")
  originalId   String    @map("original_id")
  stableUid    String    @map("stable_uid")
  username     String    @default("")
  title        String    @db.VarChar(500)
  details      String    @default("") @db.VarChar(5000)
  dueAt        DateTime? @map("due_at")
  done         Boolean   @default(false)
  doneAt       DateTime? @map("done_at")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @map("created_at")

  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@index([schoolYearId])
  @@index([schoolYearId, stableUid])
  @@map("archived_todos")
}

model ArchivedReminder {
  id                String    @id @default(uuid())
  schoolYearId      String    @map("school_year_id")
  originalId        String    @map("original_id")
  classId           String    @map("class_id")
  className         String    @default("") @map("class_name")
  title             String    @db.VarChar(500)
  body              String    @default("") @db.VarChar(5000)
  remindAt          DateTime  @map("remind_at")
  createdBy         String    @map("created_by")
  createdByName     String    @default("") @map("created_by_name")
  createdByUsername String    @default("") @map("created_by_username")
  archivedAt        DateTime? @map("archived_at")
  commentsJson      String    @default("[]") @db.Text @map("comments_json")
  createdAt         DateTime  @map("created_at")

  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id], onDelete: Cascade)

  @@index([schoolYearId])
  @@map("archived_reminders")
}

model FrontendActivityLog {
  id        String   @id @default(uuid())
  event     String   @db.VarChar(50)
  page      String?  @db.VarChar(500)
  detail    String?  @db.VarChar(500)
  stableUid String?  @map("stable_uid") @db.VarChar(64)
  username  String?  @db.VarChar(100)
  ip        String?  @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([stableUid])
  @@index([username])
  @@index([createdAt])
  @@index([event])
  @@map("frontend_activity_logs")
}
